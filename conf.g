# Configurações do Reset Fiber Home
# Coloque este arquivo na mesma pasta do binário.
# Linhas iniciadas com # são ignoradas.
# Timeouts em milissegundos.

# Modo padrão do scan lento ao abrir o programa (true/false)
slowScan=false

# Scan rápido (TCP dial)
scanWorkers=2000
scanTimeout=400

# Scan lento (HTTP GET)
scanSlowWorkers=2000
scanSlowTimeout=600
